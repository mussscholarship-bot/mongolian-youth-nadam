<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>モンゴル青年ナーダム - 参加登録</title>
</head>
<body>
    <header>
        <h1>モンゴル青年ナーダム</h1>
        <p>Mongolian Youth Nadam</p>
    </header>
    <div class="container">
        <h2>参加登録 / Registration</h2>

        <% if (error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>

        <form action="/registration/register" method="POST" id="registrationForm">
            <div class="form-group">
                <label for="name">氏名 / Name <span class="required">*</span></label>
                <input type="text" id="name" name="name" value="<%= typeof body !== 'undefined' && body.name ? body.name : '' %>" required>
            </div>

            <div class="form-group">
                <label for="email">メールアドレス / Email <span class="required">*</span></label>
                <input type="email" id="email" name="email" value="<%= typeof body !== 'undefined' && body.email ? body.email : '' %>" required>
            </div>

            <div class="form-group">
                <label for="gender">性別 / Gender <span class="required">*</span></label>
                <select id="gender" name="gender" required>
                    <option value="">-- 選択してください --</option>
                    <option value="male">男性 / Male</option>
                    <option value="female">女性 / Female</option>
                    <option value="other">その他 / Other</option>
                </select>
            </div>

            <div class="form-group">
                <label for="occupation">職業 / Occupation <span class="required">*</span></label>
                <input type="text" id="occupation" name="occupation" value="<%= typeof body !== 'undefined' && body.occupation ? body.occupation : '' %>" required>
            </div>

            <div class="form-group">
                <label for="relationship_status">婚姻状況 / Relationship Status <span class="required">*</span></label>
                <select id="relationship_status" name="relationship_status" required>
                    <option value="">-- 選択してください --</option>
                    <option value="single">独身 / Single</option>
                    <option value="in_a_relationship">交際中 / In a Relationship</option>
                    <option value="married">既婚 / Married</option>
                    <option value="divorced">離婚 / Divorced</option>
                </select>
            </div>

            <div class="form-group">
                <label for="phone">電話番号 / Phone <span class="required">*</span></label>
                <input type="tel" id="phone" name="phone" placeholder="+81XXXXXXXXXX" value="<%= typeof body !== 'undefined' && body.phone ? body.phone : '' %>" required>
            </div>

            <div class="form-group">
                <label for="hometown">出身地 / Hometown <span class="required">*</span></label>
                <input type="text" id="hometown" name="hometown" value="<%= typeof body !== 'undefined' && body.hometown ? body.hometown : '' %>" required>
            </div>

            <div class="form-group">
                <label for="current_address">現住所 / Current Address <span class="required">*</span></label>
                <input type="text" id="current_address" name="current_address" value="<%= typeof body !== 'undefined' && body.current_address ? body.current_address : '' %>" required>
            </div>

            <div class="form-group">
                <label for="interests">興味・趣味 / Interests</label>
                <textarea id="interests" name="interests" rows="3" placeholder="例: 馬術, 相撲, 音楽..."><%= typeof body !== 'undefined' && body.interests ? body.interests : '' %></textarea>
            </div>

            <div class="form-group">
                <label for="other_interest">その他 / Other Interest</label>
                <input type="text" id="other_interest" name="other_interest" value="<%= typeof body !== 'undefined' && body.other_interest ? body.other_interest : '' %>">
            </div>

            <div class="form-group checkbox-group">
                <label>
                    <input type="checkbox" name="event_time_confirmation" value="true">
                    イベントの日時を確認しました。/ I confirm the event schedule.
                </label>
            </div>

            <div class="form-group checkbox-group">
                <label>
                    <input type="checkbox" name="privacy_agreement" value="true" required>
                    プライバシーポリシーに同意します。/ I agree to the privacy policy. <span class="required">*</span>
                </label>
            </div>

            <div class="form-group">
                <button type="submit" class="btn-submit">登録する / Register</button>
            </div>
        </form>
    </div>
    <footer>
        <p>&copy; 2024 Mongolian Youth Nadam. All rights reserved.</p>
    </footer>
</body>
</html>
