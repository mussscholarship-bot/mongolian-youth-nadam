<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>管理者ログイン - モンゴル青年ナーダム</title>
</head>
<body>
    <header>
        <h1>管理者ログイン / Admin Login</h1>
    </header>
    <div class="container">
        <% if (error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>
        <form action="/admin/login" method="POST" style="max-width:400px;margin:40px auto;">
            <div class="form-group">
                <label for="username">ユーザー名 / Username</label>
                <input type="text" id="username" name="username" required autofocus>
            </div>
            <div class="form-group">
                <label for="password">パスワード / Password</label>
                <input type="password" id="password" name="password" required>
            </div>
            <div class="form-group">
                <button type="submit" class="btn-submit">ログイン / Login</button>
            </div>
        </form>
    </div>
    <footer>
        <p>&copy; 2024 Mongolian Youth Nadam. All rights reserved.</p>
    </footer>
</body>
</html>
